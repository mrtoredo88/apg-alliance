rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Каталог и контент — читают все, пишет только Admin SDK (backend) ──────
    // AdminPanel читает через Firestore SDK, пишет через /api/admin-actions.
    // Пользовательское приложение читает напрямую как fallback после public-data API.
    match /partners/{id} {
      allow read: if true;
      allow write: if false;

      // Отзывы партнёра пишет только user-actions (Admin SDK).
      match /reviews/{userId} {
        allow read: if true;
        allow write: if false;
      }
    }
    match /experts/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /events/{id} {
      allow read: if true;
      allow write: if false;

      // event:toggle идёт через backend (Admin SDK) — клиент не пишет.
      match /registrations/{userId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
    match /news/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /prizes/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /notifications/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /conversationRequests/{id} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/auth_map/$(request.auth.uid))
        && get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data.vkId in resource.data.participants;
      allow write: if false;
    }
    match /customTasks/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /stats/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /monthlyWinners/{month} {
      allow read: if true;
      allow write: if false;
    }
    match /lokiKnowledge/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ── Отзывы (верхний уровень) — читают все, пишет только user-actions ──────
    match /reviews/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /expertReviews/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ── Участие в розыгрышах — raffle:enter через backend (Admin SDK) ─────────
    // Читают авторизованные: своё участие и счётчики по prizeId.
    match /raffleEntries/{entryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Призовые выдачи — prize:claim через backend, читает AdminPanel API ────
    match /prizeClaims/{id} {
      allow read, write: if false;
    }

    // ── Данные пользователей ──────────────────────────────────────────────────
    // Чтение документа открыто любому авторизованному пользователю —
    // необходимо для лидерборда (where('keys', '>', N)).
    // Запись и чтение подколлекций (activity, claims) — только владелец.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOwner(userId);

      match /socialMessagingRequests/{requestId} {
        allow read: if request.auth != null && isOwner(userId);
        allow write: if false;
      }
      match /blockedUsers/{blockedUserId} {
        allow read: if request.auth != null && isOwner(userId);
        allow write: if false;
      }
      match /connections/{connectionId} {
        allow read: if request.auth != null && isOwner(userId);
        allow write: if false;
      }
      match /{sub}/{docId} {
        allow read, write: if request.auth != null && isOwner(userId)
          && !(sub in ['socialMessagingRequests', 'blockedUsers', 'connections']);
      }
    }

    // ── Маппинг Firebase UID → userId ─────────────────────────────────────────
    // Пользователь может создать только свою запись; обновление — только backend.
    match /auth_map/{firebaseUid} {
      allow read:   if request.auth != null && request.auth.uid == firebaseUid;
      allow create: if request.auth != null && request.auth.uid == firebaseUid;
      allow update, delete: if false;
    }

    // ── Сессии Telegram-авторизации — только Admin SDK ───────────────────────
    match /telegramAuthSessions/{id} {
      allow read, write: if false;
    }

    // ── Аналитика гостей — только Admin SDK ──────────────────────────────────
    match /guestSessions/{id} {
      allow read, write: if false;
    }

    // ── Лог клиентских ошибок — только Admin SDK ─────────────────────────────
    // log:error идёт через user-actions backend; AdminPanel читает через admin-actions.
    match /errorLogs/{id} {
      allow read, write: if false;
    }

    // ── Сканы для activityIndex — только Admin SDK ────────────────────────────
    match /scans/{id} {
      allow read, write: if false;
    }

    function isOwner(userId) {
      return exists(/databases/$(database)/documents/auth_map/$(request.auth.uid))
          && (
            get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data.vkId == userId
            || get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data.userId == userId
            || get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data.canonicalUserId == userId
          );
    }
  }
}
