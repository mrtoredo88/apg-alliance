rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Публичные коллекции — только чтение для клиентов ─────────────────────
    // Запись только через Firebase Console или Admin SDK (backend).
    // AdminPanel на клиенте работает через auth: любой авторизованный пользователь
    // может писать сюда; реальная защита — через отдельный admin-токен на бэкенде.
    match /partners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{id} {
      allow read: if true;
      allow write: if request.auth != null;

      match /registrations/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && isOwner(userId);
      }
    }
    match /news/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /prizes/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /notifications/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /prizeClaims/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    match /customTasks/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Отзывы — чтение всем, запись только авторизованным ───────────────────
    match /reviews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Отзывы партнёров (подколлекция) ──────────────────────────────────────
    // Документ хранится по пути partners/{id}/reviews/{userId} где userId — VK id
    match /partners/{partnerId}/reviews/{userId} {
      allow read: if true;
      allow write: if request.auth != null && isOwner(userId);
    }

    // ── Данные пользователей ──────────────────────────────────────────────────
    // Чтение документа открыто любому авторизованному пользователю —
    // это необходимо для рейтинга (leaderboard) и аналитики.
    // Запись и чтение подколлекций (activity, claims) — только владелец.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && isOwner(userId);

      match /{sub}/{docId} {
        allow read, write: if request.auth != null
                           && isOwner(userId);
      }
    }

    // ── Скан-события для расчёта activityIndex ───────────────────────────────
    // Клиент только пишет; читает только Admin SDK (backend).
    match /scans/{id} {
      allow read: if false;
      allow create: if request.auth != null;
    }

    // ── Победители месяца — читают все, пишет только Admin SDK ───────────────
    match /monthlyWinners/{month} {
      allow read: if true;
      allow write: if false;
    }

    // ── Маппинг Firebase UID → VK user id ────────────────────────────────────
    // Создаётся при первом входе; пользователь может только создать свою запись.
    match /auth_map/{firebaseUid} {
      allow read:   if request.auth != null && request.auth.uid == firebaseUid;
      allow create: if request.auth != null && request.auth.uid == firebaseUid;
      allow update, delete: if false;
    }

    function isOwner(userId) {
      return exists(/databases/$(database)/documents/auth_map/$(request.auth.uid))
          && get(/databases/$(database)/documents/auth_map/$(request.auth.uid)).data.vkId == userId;
    }
  }
}
