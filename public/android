<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#17120a">
  <meta name="description" content="Скачать официальное Android-приложение АПГ для Android 10 и новее.">
  <title>АПГ для Android</title>
  <style>
    :root{color-scheme:light;--ink:#17120a;--muted:#6f6759;--gold:#c9a84c;--paper:#faf5e8;--line:rgba(77,58,20,.16)}
    *{box-sizing:border-box}body{margin:0;font-family:Manrope,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:var(--ink);background:radial-gradient(circle at 20% 0,#fff9df 0,transparent 32%),linear-gradient(150deg,#f4ead0,#f8f5ed 58%,#e8dfc9);min-height:100vh}
    main{width:min(760px,100%);margin:auto;padding:calc(28px + env(safe-area-inset-top)) 18px calc(42px + env(safe-area-inset-bottom))}
    .hero,.card{border:1px solid rgba(255,255,255,.75);background:rgba(255,255,255,.62);box-shadow:0 22px 70px rgba(74,54,16,.13),inset 0 1px rgba(255,255,255,.9);backdrop-filter:blur(18px);border-radius:30px}
    .hero{padding:clamp(22px,5vw,42px);text-align:center}.logo{width:92px;height:92px;border-radius:28px;box-shadow:0 18px 42px rgba(36,22,74,.24)}
    .eyebrow{margin:22px 0 8px;color:#9d7820;font-size:12px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}h1{margin:0;font-size:clamp(38px,8vw,64px);line-height:1.02;letter-spacing:-.04em}p{color:var(--muted);line-height:1.65}
    .download{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;min-height:58px;margin-top:24px;border:0;border-radius:19px;color:#fff9e8;background:var(--ink);font-size:16px;font-weight:850;text-decoration:none;box-shadow:0 14px 30px rgba(23,18,10,.2)}
    .meta{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-top:14px}.pill{padding:7px 11px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.52);font-size:12px;font-weight:750;color:var(--muted)}
    .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;margin-top:16px}.card{padding:22px}.wide{grid-column:1/-1}h2{margin:0 0 12px;font-size:21px}.step{display:grid;grid-template-columns:34px 1fr;gap:10px;margin:12px 0;align-items:start}.num{width:34px;height:34px;border-radius:12px;display:grid;place-items:center;background:#ead38c;font-weight:900}.step strong{display:block;margin:2px 0 3px}.step span:last-child{font-size:13px;line-height:1.45;color:var(--muted)}
    .hash{display:block;padding:12px;border:1px solid var(--line);border-radius:13px;background:rgba(255,255,255,.58);font:11px/1.5 ui-monospace,SFMono-Regular,monospace;overflow-wrap:anywhere}.copy{margin-top:10px;border:1px solid var(--line);border-radius:12px;background:white;padding:9px 12px;font-weight:750;cursor:pointer}
    .notice{border-left:4px solid var(--gold);padding-left:14px}.links{display:flex;flex-wrap:wrap;gap:14px;margin-top:20px;justify-content:center}.links a{color:#715412;font-weight:750}
    @media(max-width:620px){.grid{grid-template-columns:1fr}.wide{grid-column:auto}.hero,.card{border-radius:24px}}
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <img class="logo" src="/icon.png" alt="Логотип АПГ">
      <div class="eyebrow">Официальная Android-версия</div>
      <h1>АПГ всегда рядом</h1>
      <p>Установите отдельное приложение АПГ. Поддерживается Android 10 и новее.</p>
      <a class="download" id="download" href="/downloads/apg-android.apk" download>Скачать APK для Android</a>
      <div class="meta">
        <span class="pill" id="version">Версия 1.1.0</span>
        <span class="pill" id="size">≈ 16 МБ</span>
        <span class="pill">Android 10+</span>
        <span class="pill">Подписано APG Team</span>
      </div>
    </section>

    <div class="grid">
      <section class="card">
        <h2>Как установить</h2>
        <div class="step"><span class="num">1</span><span><strong>Скачайте APK</strong><span>Нажмите кнопку выше и дождитесь окончания загрузки.</span></span></div>
        <div class="step"><span class="num">2</span><span><strong>Разрешите установку</strong><span>Android может попросить разрешение для вашего браузера — это штатно для загрузки вне магазина.</span></span></div>
        <div class="step"><span class="num">3</span><span><strong>Откройте АПГ</strong><span>При обновлении новая версия установится поверх старой и сохранит данные приложения.</span></span></div>
      </section>

      <section class="card">
        <h2>Безопасность</h2>
        <p class="notice">APK подписан постоянным release-сертификатом АПГ. Не устанавливайте копии с других сайтов.</p>
        <strong>SHA-256</strong>
        <code class="hash" id="sha">Загрузка контрольной суммы…</code>
        <button class="copy" id="copy" type="button">Скопировать SHA-256</button>
      </section>

      <section class="card wide">
        <h2>Что важно знать</h2>
        <p>Приложение использует существующую защищённую систему АПГ и production API по HTTPS. Для установки требуется примерно 30 МБ свободного места. Обновления будут появляться на этой странице.</p>
        <div class="links">
          <a href="/privacy-policy.html">Политика конфиденциальности</a>
          <a href="/user-agreement.html">Пользовательское соглашение</a>
          <a href="/">Вернуться в АПГ</a>
        </div>
      </section>
    </div>
  </main>
  <script>
    const manifestUrl='/downloads/android-release.json';
    fetch(manifestUrl,{cache:'no-store'}).then(r=>r.ok?r.json():Promise.reject()).then(release=>{
      if(release.apkUrl)document.querySelector('#download').href=release.apkUrl;
      if(release.versionName)document.querySelector('#version').textContent=`Версия ${release.versionName}`;
      if(release.sizeBytes)document.querySelector('#size').textContent=`${(release.sizeBytes/1048576).toFixed(1)} МБ`;
      if(release.sha256)document.querySelector('#sha').textContent=release.sha256;
    }).catch(()=>{document.querySelector('#sha').textContent='Сверка временно недоступна';});
    document.querySelector('#copy').addEventListener('click',async()=>{
      const value=document.querySelector('#sha').textContent;
      if(!/^[a-f0-9]{64}$/.test(value))return;
      await navigator.clipboard.writeText(value);
      document.querySelector('#copy').textContent='Скопировано';
    });
  </script>
</body>
</html>
