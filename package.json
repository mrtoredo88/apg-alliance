{
  "name": "apg-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "local:pwa": "npm run build && node scripts/serve-local-prod.mjs",
    "local:pwa:http": "npm run build && node scripts/serve-local-prod.mjs --http",
    "knowledge:update": "node scripts/update-apg-chronicles.mjs",
    "demo:emulator": "firebase emulators:start --only firestore --project project-apg-bbfc8",
    "demo:seed": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/demo-content.mjs",
    "demo:clear": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8080 node scripts/demo-content.mjs --clear",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test:news-article": "node scripts/news-article-regression.mjs",
    "test:loki": "node scripts/loki-core-v2-test.mjs",
    "test:admin-assistant": "node scripts/admin-assistant-v1-test.mjs",
    "smoke:prod": "node scripts/prod-smoke.mjs",
    "preview": "vite preview",
    "tunnel": "vk-tunnel --http-protocol=http --host=localhost --port=5173",
    "deploy": "vite build && vk-miniapps-deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@vkontakte/icons": "^3.53.0",
    "@vkontakte/vk-bridge": "^2.15.12",
    "@vkontakte/vk-bridge-react": "^1.0.1",
    "@vkontakte/vk-mini-apps-router": "^1.7.6",
    "@vkontakte/vkui": "^7.11.7",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "nodemailer": "^9.0.3",
    "qr-scanner": "^1.4.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^5.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vkontakte/vk-miniapps-deploy": "^0.1.6",
    "@vkontakte/vk-tunnel": "^0.2.4",
    "eruda": "^3.0.1",
    "esbuild": "~0.20.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-tools": "^15.20.0",
    "playwright": "^1.60.0",
    "terser": "^5.4.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.3.0"
  }
}
